    "show-trace": "playwright show-trace",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.10.2",
    "dotenv": "^17.2.3",
    "typescript": "^5.7.2"
  }
}
